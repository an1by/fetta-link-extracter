{
    "manifest_version": 3,
    "name": "фетта → OZON",
    "version": "1.0.2",
    "author": "An1by (https://github.com/an1by)",
    "description": "Добавляет к карточкам товаров на fetta.app ссылку на OZON",
    "icons": {
        "16": "assets/icon-16.png",
        "48": "assets/icon-48.png",
        "64": "assets/icon-64.png",
        "128": "assets/icon-128.png"
    },
    "host_permissions": [
        "https://fetta.app/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://fetta.app/u/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js"
            ],
            "matches": [
                "https://fetta.app/*"
            ]
        }
    ]
}