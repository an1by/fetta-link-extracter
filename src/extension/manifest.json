{
    "manifest_version": 3,
    "name": "фетта → OZON",
    "version": "0.0.0",
    "author": "An1by (https://github.com/an1by)",
    "description": "Добавляет к карточкам товаров на fetta.app ссылку на OZON",
    "icons": {
        "16": "assets/icon-16.png",
        "48": "assets/icon-48.png",
        "64": "assets/icon-64.png",
        "128": "assets/icon-128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "fetta-ozon@an1by.github.io",
            "strict_min_version": "140.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        },
        "gecko_android": {
            "strict_min_version": "142.0"
        }
    },
    "host_permissions": [
        "https://fetta.app/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://fetta.app/u/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js"
            ],
            "matches": [
                "https://fetta.app/*"
            ]
        }
    ]
}