{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "extension",
    "rootDir": "src/extension",
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "types": [
      "chrome"
    ],
    "lib": [
      "ES2020",
      "DOM"
    ]
  },
  "include": ["src/extension/**/*.ts"],
  "exclude": [
    "node_modules"
  ]
}